---
import BaseLayout from '../../layouts/BaseLayout.astro';
import financeData from '../../data/finances/wise.json';

const { balance, balance_currency, balance_updated, transactions } = financeData;

// Last-month summary: find the most recent month in the data
const months = [...new Set(transactions.map(t => t.date?.slice(0, 7)))].sort().reverse();
const lastMonth = months[0];
const lastMonthLabel = lastMonth
  ? new Date(lastMonth + '-01').toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  : null;

const lastMonthTxns = transactions.filter(t => t.date?.startsWith(lastMonth ?? ''));
const lastMonthOut = lastMonthTxns.filter(t => t.direction === 'OUT');
const lastMonthIn = lastMonthTxns.filter(t => t.direction === 'IN');

const totalOut = lastMonthOut.reduce((sum, t) => sum + t.amount, 0);
const totalIn = lastMonthIn.reduce((sum, t) => sum + t.amount, 0);

// Category breakdown for outflows
const byCategory: Record<string, number> = {};
for (const t of lastMonthOut) {
  const cat = t.category ?? 'Uncategorized';
  byCategory[cat] = (byCategory[cat] ?? 0) + t.amount;
}
const categoryBreakdown = Object.entries(byCategory).sort((a, b) => b[1] - a[1]);

const formatAmount = (amount: number, currency: string) =>
  `${currency === 'EUR' ? '€' : ''}${amount} ${currency}`;
---

<BaseLayout title="Finances">
  <div class="max-w-3xl">
    <h1 class="text-3xl font-bold mb-1">Finances</h1>
    <p class="text-gray-500 mb-8">Approximate balances and transactions, rounded to the nearest dollar.</p>

    <!-- Current Balance -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
      <p class="text-sm text-gray-500 uppercase tracking-wide mb-1">Current Balance (Wise)</p>
      <p class="text-4xl font-bold text-gray-900">
        {balance !== null ? formatAmount(balance, balance_currency) : '—'}
      </p>
      {balance_updated && (
        <p class="text-xs text-gray-400 mt-1">Updated {balance_updated}</p>
      )}
    </div>

    <!-- Last Month Summary -->
    {lastMonth && (
      <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
        <h2 class="text-lg font-semibold mb-4">{lastMonthLabel} Summary</h2>
        <div class="flex gap-8 mb-4">
          <div>
            <p class="text-sm text-gray-500">Spent</p>
            <p class="text-2xl font-bold text-red-600">€{totalOut} EUR</p>
          </div>
          {totalIn > 0 && (
            <div>
              <p class="text-sm text-gray-500">Received</p>
              <p class="text-2xl font-bold text-green-600">€{totalIn} EUR</p>
            </div>
          )}
        </div>
        {categoryBreakdown.length > 0 && (
          <div class="space-y-1">
            {categoryBreakdown.map(([cat, amount]) => (
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">{cat}</span>
                <span class="font-mono text-gray-800">€{amount}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- Transaction Table -->
    {transactions.length > 0 ? (
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <h2 class="text-lg font-semibold p-6 pb-0">Transactions</h2>
        <div class="overflow-x-auto mt-4">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-y border-gray-200">
              <tr>
                <th class="text-left px-6 py-3 text-gray-500 font-medium">Date</th>
                <th class="text-left px-4 py-3 text-gray-500 font-medium">Direction</th>
                <th class="text-right px-4 py-3 text-gray-500 font-medium">Amount</th>
                <th class="text-left px-4 py-3 text-gray-500 font-medium">Merchant</th>
                <th class="text-left px-4 py-3 text-gray-500 font-medium hidden sm:table-cell">Category</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {transactions.map(t => (
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-3 font-mono text-gray-500 whitespace-nowrap">{t.date}</td>
                  <td class="px-4 py-3">
                    <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${t.direction === 'IN' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                      {t.direction}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-right font-mono">
                    {formatAmount(t.amount, t.currency)}
                  </td>
                  <td class="px-4 py-3 text-gray-700 max-w-[200px] truncate">{t.merchant}</td>
                  <td class="px-4 py-3 text-gray-500 hidden sm:table-cell">{t.category ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ) : (
      <p class="text-gray-400 text-sm">No transactions yet. Run the import script to populate data.</p>
    )}
  </div>
</BaseLayout>
