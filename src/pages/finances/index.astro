---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinancesDashboard from '../../components/FinancesDashboard';
import wiseData from '../../data/finances/wise.json';
import rbcData from '../../data/finances/rbc.json';

const DISPLAY_CURRENCY = 'CAD';
const SUPPORTED_CURRENCIES = ['CAD', 'EUR', 'USD', 'GBP'];

// Fetch exchange rates at build time (from CAD, so rates[X] = how many X per 1 CAD)
let toCadRates: Record<string, number> = {};
try {
  const res = await fetch(`https://api.frankfurter.app/latest?from=${DISPLAY_CURRENCY}`);
  const data = await res.json();
  toCadRates = data.rates ?? {};
  toCadRates[DISPLAY_CURRENCY] = 1;
} catch {
  // Fallback: no conversion, show raw balances only
}

// Rates for supported display currencies (CAD → X)
const cadRates: Record<string, number> = Object.fromEntries(
  SUPPORTED_CURRENCIES.map(c => [c, toCadRates[c] ?? 1])
);

const convertToDisplay = (amount: number, currency: string): number => {
  if (currency === DISPLAY_CURRENCY) return amount;
  const rate = toCadRates[currency];
  return rate ? Math.round(amount / rate) : 0;
};

// Wise account
const wiseSubBalances = Object.entries(wiseData.balances).filter(([, amount]) => amount > 0);
const wiseTotal = wiseSubBalances.reduce((sum, [currency, amount]) => sum + convertToDisplay(amount, currency), 0);

// RBC account
const rbcTotal = rbcData.sub_accounts.reduce((sum, a) => sum + convertToDisplay(a.amount, a.currency), 0);

// Grand total
const grandTotal = wiseTotal + rbcTotal;

// Transactions (combined, sorted by date descending)
const allTransactions = [
  ...wiseData.transactions.map(t => ({ ...t, source: 'wise' as const })),
  ...rbcData.transactions.map(t => ({ ...t, source: 'rbc' as const })),
].sort((a, b) => (b.date ?? '').localeCompare(a.date ?? ''));

const transactions = allTransactions;

// Net income & expense chart data
type MonthlyDataPoint = { label: string; income: number; expenses: number; net: number; balance: number };

const buildMonthlyData = (numMonths: number): MonthlyDataPoint[] => {
  const today = new Date('2026-06-20');
  const months: string[] = [];
  for (let i = numMonths - 1; i >= 0; i--) {
    const d = new Date(today.getFullYear(), today.getMonth() - i, 1);
    months.push(`${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`);
  }
  const buckets: Record<string, { income: number; expenses: number }> = {};
  for (const m of months) buckets[m] = { income: 0, expenses: 0 };
  for (const t of allTransactions) {
    const m = t.date?.slice(0, 7);
    if (m && buckets[m]) {
      const cad = convertToDisplay(t.amount, t.currency);
      if (t.direction === 'IN') buckets[m].income += cad;
      else buckets[m].expenses += cad;
    }
  }
  const result: MonthlyDataPoint[] = [];
  let runningBalance = grandTotal;
  for (let i = months.length - 1; i >= 0; i--) {
    const m = months[i];
    const { income, expenses } = buckets[m];
    const net = income - expenses;
    const label = new Date(m + '-02').toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
    result.unshift({ label, income, expenses, net, balance: Math.round(runningBalance) });
    runningBalance -= net;
  }
  return result;
};

const monthlyData6 = buildMonthlyData(6);
const monthlyData12 = buildMonthlyData(12);

const months = [...new Set(transactions.map(t => t.date?.slice(0, 7)))].sort().reverse();
const lastMonth = months[0];
const lastMonthLabel = lastMonth
  ? new Date(lastMonth + '-01').toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  : null;

const lastMonthTxns = transactions.filter(t => t.date?.startsWith(lastMonth ?? ''));
const lastMonthOut = lastMonthTxns.filter(t => t.direction === 'OUT');
const lastMonthIn = lastMonthTxns.filter(t => t.direction === 'IN');

const totalOut = lastMonthOut.reduce((sum, t) => sum + convertToDisplay(t.amount, t.currency), 0);
const totalIn = lastMonthIn.reduce((sum, t) => sum + convertToDisplay(t.amount, t.currency), 0);

const byCategory: Record<string, number> = {};
for (const t of lastMonthOut) {
  const cat = t.category ?? 'Uncategorized';
  byCategory[cat] = (byCategory[cat] ?? 0) + convertToDisplay(t.amount, t.currency);
}
const categoryBreakdown = Object.entries(byCategory).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Finances">
  <div class="max-w-3xl">
    <h1 class="text-3xl font-bold mb-1">Finances</h1>
    <p class="text-gray-500 mb-8">Approximate balances and transactions, rounded to the nearest dollar.</p>

    <FinancesDashboard
      grandTotalCad={grandTotal}
      wiseTotalCad={wiseTotal}
      rbcTotalCad={rbcTotal}
      wiseSubBalances={wiseSubBalances}
      rbcSubAccounts={rbcData.sub_accounts}
      wiseUpdated={wiseData.balance_updated}
      rbcUpdated={rbcData.balance_updated}
      rbcLabel={rbcData.label}
      monthlyData6={monthlyData6}
      monthlyData12={monthlyData12}
      totalOutCad={totalOut}
      totalInCad={totalIn}
      categoryBreakdownCad={categoryBreakdown}
      lastMonthLabel={lastMonthLabel}
      cadRates={cadRates}
      client:only="react"
    />

    <!-- Transaction Table -->
    {transactions.length > 0 ? (
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <h2 class="text-lg font-semibold p-6 pb-0">Transactions</h2>
        <div class="overflow-x-auto mt-4">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-y border-gray-200">
              <tr>
                <th class="text-left px-6 py-3 text-gray-500 font-medium">Date</th>
                <th class="text-left px-4 py-3 text-gray-500 font-medium">Direction</th>
                <th class="text-right px-4 py-3 text-gray-500 font-medium">Amount</th>
                <th class="text-left px-4 py-3 text-gray-500 font-medium">Merchant</th>
                <th class="text-left px-4 py-3 text-gray-500 font-medium">Category</th>
                <th class="text-left px-4 py-3 text-gray-500 font-medium">Source</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {transactions.map(t => (
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-3 font-mono text-gray-500 whitespace-nowrap">{t.date}</td>
                  <td class="px-4 py-3">
                    <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${t.direction === 'IN' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                      {t.direction}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-right font-mono">{t.amount} {t.currency}</td>
                  <td class="px-4 py-3 text-gray-700 max-w-[200px] truncate">{t.merchant}</td>
                  <td class="px-4 py-3 text-gray-500">{t.category ?? '—'}</td>
                  <td class="px-4 py-3">
                    <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">
                      {t.source === 'wise' ? 'Wise' : t.account_type === 'chequing' ? 'Bank:CHQ' : t.account_type === 'savings' ? 'Bank:SAV' : 'Bank'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ) : (
      <p class="text-gray-400 text-sm">No transactions yet. Run the import script to populate data.</p>
    )}
  </div>
</BaseLayout>
